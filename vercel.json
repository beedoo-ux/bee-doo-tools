{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "enpal.bee-doo.de"
        }
      ],
      "destination": "/enpal-board.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "ranking.bee-doo.de"
        }
      ],
      "destination": "/vt-ranking.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Bee-Doo-Version",
          "value": "2.0"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-sync?sync=leveto_sync",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron-sync?sync=leveto_contracts",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron-sync?sync=auto_merge",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/efs-sync",
      "schedule": "0 5 * * *"
    }
  ]
}
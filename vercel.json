{
  "redirects": [
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "enpal.bee-doo.de"
        }
      ],
      "destination": "/enpal-board.html",
      "permanent": false
    },
    {
      "source": "/",
      "has": [
        {
          "type": "host",
          "value": "ranking.bee-doo.de"
        }
      ],
      "destination": "/vt-ranking.html",
      "permanent": false
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Bee-Doo-Version",
          "value": "2.0"
        }
      ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron-sync?sync=auto_merge",
      "schedule": "30 6 * * *"
    },
    {
      "path": "/api/efs-sync",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/sevdesk-sync",
      "schedule": "0 */4 * * *"
    },
    {
      "path": "/api/cron-sync?sync=scout_sync",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/enpal-leads-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron-sync?sync=infas_coords",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/leveto-overview-sync",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/reputation-scan",
      "schedule": "0 */2 * * *"
    },
    {
      "path": "/api/cron-challenge",
      "schedule": "0 5-21 * * *"
    },
    {
      "path": "/api/cron-morgenplan",
      "schedule": "55 5 * * 1-6"
    },
    {
      "path": "/api/contracts-status-sync",
      "schedule": "15,45 * * * *"
    }
  ],
  "cleanUrls": true
}
